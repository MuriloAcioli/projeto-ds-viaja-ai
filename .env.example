# Copie este arquivo para .env e preencha com os valores reais.
# O .env NÃO é versionado (ver .gitignore). Nunca commite chaves reais.

# --- IA (obrigatória para gerar roteiros) ---
GEMINI_API_KEY=

# --- Integrações externas (opcionais; há fallback/mocks quando ausentes) ---
SERPAPI_API_KEY=
TRIPADVISOR_API_KEY=
OPENWEATHERMAP_API_KEY=

# --- Autenticação ---
# Gere um valor aleatório forte em produção, ex: openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-trocar-em-producao
